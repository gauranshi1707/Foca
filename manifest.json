{
  "manifest_version": 3,
  "name": "Foca",
  "version": "2.0.0",
  "description": "Focus without blocking your learning.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "offscreen"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.instagram.com/*",
        "*://*.linkedin.com/*"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Open Foca Popup"
    },
    "toggle-study-mode": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "MacCtrl+Shift+S"
      },
      "description": "Toggle Study Mode"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/quotes.json",
        "background/offscreen.html"
      ],
      "matches": [
        "*://*.youtube.com/*",
        "*://*.instagram.com/*",
        "*://*.linkedin.com/*",
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
